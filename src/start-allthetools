#!/bin/bash
set -euo pipefail

SERVICE_SCRIPT_DIR=/opt/allthetools/services/active

log() {
  echo "$*"
}

pids=()
start_background() {
  "$@" &
  pids+=($!)
}

cleanup() {
  log "Cleaning up..."
  kill -TERM "${pids[@]}" 2>/dev/null || true
  wait 2>/dev/null || true
}
trap cleanup TERM INT

main() {
  service_scripts="$(
    find -L "${SERVICE_SCRIPT_DIR}" -maxdepth 1 -mindepth 1 -executable -type f \
      | sort
  )"

  log "Starting services..."
  while read -r script; do
    if [ "${script}" == "" ]; then
      continue
    fi
    log "Starting: ${script}"
    start_background "${script}" </dev/null
  done < <(echo "${service_scripts}")

  # Exit as soon as any supervised process dies, so tini tears the container down.
  wait -n
  status=$?
  cleanup
  exit "$status"
}

main "$@"
